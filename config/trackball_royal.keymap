#include "keys_ru.h"
#include <dt-bindings/zmk/input_transform.h>
#include <input/processors.dtsi>
#include <zephyr/dt-bindings/input/input-event-codes.h>
#include <dt-bindings/zmk/matrix_transform.h>
#include <scroll-snap.dtsi>
#include <behaviors.dtsi>
#include <dt-bindings/zmk/bt.h>
#include <dt-bindings/zmk/outputs.h>
#include <dt-bindings/zmk/pointing.h>
#include "input/processors/sensor_rotation.dtsi"
#include <input/processors/keybind.dtsi>

/ {
    default_transform: keymap_transform_0 {
        compatible = "zmk,matrix-transform";
        columns = <2>;
        rows = <3>;
        map = <
        RC(0,3) RC(0,2)
        RC(0,0) RC(0,1)
        RC(0,5) RC(0,4)
        >;
    };

    combos {
        compatible = "zmk,combos";

        base_combo {
            bindings = <&mkp MB3>;
            key-positions = <0 1>;
        };
    };

    behaviors {

        // Левая верхняя: tap=MB2, hold=scroll layer
        lt_mb2: lt_mb2 {
            compatible = "zmk,behavior-hold-tap";
            label = "LT_MB2";
            #binding-cells = <2>;
            flavor = "balanced";
            tapping-term-ms = <200>;
            bindings = <&mo>, <&mkp>;
        };

        // Левая верхняя: 1 тап/hold=MB2+scroll, быстрый tap+hold=MEH
        td_left_top: td_left_top {
            compatible = "zmk,behavior-tap-dance";
            label = "TD_LEFT_TOP";
            #binding-cells = <0>;
            tapping-term-ms = <200>;
            bindings = <&lt_mb2 1 MB2>, <&kp LS(LA(LCTRL))>;
        };

        // Правая средняя: tap=MB3, hold=Ctrl
        ctrl_mb3: ctrl_mb3 {
            compatible = "zmk,behavior-hold-tap";
            label = "CTRL_MB3";
            #binding-cells = <2>;
            flavor = "tap-preferred";
            tapping-term-ms = <200>;
            bindings = <&kp>, <&mkp>;
        };

        // Левая средняя: tap=залипнуть в text mode, hold=text mode пока зажата
        dpi_text: dpi_text {
            compatible = "zmk,behavior-hold-tap";
            label = "DPI_TEXT";
            #binding-cells = <2>;
            flavor = "tap-preferred";
            tapping-term-ms = <200>;
            bindings = <&mo>, <&tog>;
        };

        adj1: adj1 {
            compatible = "zmk,behavior-tap-dance";
            label = "ADJ1";
            #binding-cells = <0>;
            // 1 тап — след. BT профиль, 2 тапа — USB↔BLE
            bindings = <&bt BT_NXT>, <&out OUT_TOG>;
        };

        adj2: adj2 {
            compatible = "zmk,behavior-tap-dance";
            label = "ADJ2";
            #binding-cells = <0>;
            // 1 тап — BT профиль 0, 2 тапа — очистить все
            bindings = <&bt BT_SEL 0>, <&bt BT_CLR_ALL>;
        };
    };

    keymap {
        compatible = "zmk,keymap";

        base {
            bindings = <
&td_left_top        &mkp MB1
&dpi_text 3 3       &ctrl_mb3 LCTRL MB3
&adj1               &adj2
            >;
            display-name = "Base";
        };

        scroll {
            bindings = <
&trans  &trans
&trans  &trans
&trans  &trans
            >;
            display-name = "Scroll";
        };

        sniper {
            bindings = <
&trans  &trans
&trans  &trans
&trans  &trans
            >;
            display-name = "Sniper";
        };

        text_mode {
            bindings = <
&trans  &trans
&trans  &trans
&trans  &trans
            >;
            display-name = "Text";
        };
    };

    input_processors {
        sensor_rotation: sensor_rotation {
            compatible = "zmk,input-processor-sensor-rotation";
            status = "okay";
            #input-processor-cells = <0>;
            rotation-angle = <5>;
        };

        // Text mode: квантование движений в стрелки
        // threshold=50: накопить 50 единиц движения → 1 нажатие стрелки
        text_nav: text_nav {
            compatible = "zmk,input-processor-keybind";
            #input-processor-cells = <0>;
            x-bindings = <&kp RIGHT>, <&kp LEFT>;
            y-bindings = <&kp DOWN>, <&kp UP>;
            threshold = <50>;
        };
    };
};

&trackball { cpi = <500>; };

&trackball_listener {
    input-processors = <&sensor_rotation>;

    scroller {
        layers = <1>;
        input-processors =
            <&zip_xy_transform INPUT_TRANSFORM_Y_INVERT>,
            <&zip_xy_scaler 1 16>,
            <&zip_xy_to_scroll_mapper &zip_scroll_snap>;
    };

    sniper {
        layers = <2>;
        input-processors = <&zip_xy_scaler 1 4>;
    };

    text_mode {
        layers = <3>;
        input-processors = <&text_nav>;
    };
};
